<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DADA Enterprise | Client Portal</title>
    <link rel="stylesheet" href="/style.css">

</head>
<body class="bg-background text-foreground min-h-screen font-sans flex flex-col">

    <header class="bg-primary text-primary-fg px-4 sm:px-6 py-4 flex flex-wrap justify-between items-center gap-4 shadow-md sticky top-0 z-50">
        <div class="flex items-center gap-2 sm:gap-4">
            <div class="w-8 h-8 bg-accent text-primary flex items-center justify-center font-bold rounded shadow-inner">D</div>
            <h1 class="text-lg sm:text-xl font-serif-custom tracking-wider font-semibold">DADA ENTERPRISE</h1>
            <span class="border border-white/20 bg-white/10 text-white text-[9px] sm:text-[10px] px-2 py-1 rounded-full ml-1 sm:ml-2 uppercase tracking-widest">Client Portal</span>
        </div>
        <div class="flex items-center gap-3 sm:gap-4">
            <span class="text-xs sm:text-sm opacity-80 hidden sm:block">Welcome back</span>
            <a href="/logout" class="text-xs sm:text-sm font-medium hover:text-accent transition">🚪 Logout</a>
        </div>
    </header>

    <main class="flex-grow max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
        
        <div class="flex gap-2 border-b border-border mb-8 overflow-x-auto whitespace-nowrap pb-1">
            <button onclick="switchTab('order')" id="tab-btn-order" class="px-6 py-3 border-b-2 border-primary font-bold text-primary transition rounded-t">
                🛒 Place Bulk Order
            </button>
            <button onclick="switchTab('history')" id="tab-btn-history" class="px-6 py-3 border-b-2 border-transparent text-muted-fg hover:text-foreground transition rounded-t">
                📦 Order History
            </button>
            <button onclick="switchTab('reports')" id="tab-btn-reports" class="px-6 py-3 border-b-2 border-transparent text-muted-fg hover:text-foreground transition rounded-t">
                📊 Reports
            </button>
        </div>

        <div id="section-order" class="space-y-6">
            <form action="/customer/place-order" method="POST" class="bg-card rounded-xl border border-border p-6 md:p-8 shadow-sm">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h3 class="text-lg font-serif-custom font-bold text-foreground">Bulk Order Matrix</h3>
                        <p class="text-sm text-muted-fg mt-1">Enter quantities for any branch. Leave blank if a branch doesn't need a product today.</p>
                    </div>
                    <button type="button" onclick="document.getElementById('branchModal').classList.remove('hidden')" class="text-sm font-medium text-primary hover:text-accent transition flex items-center gap-1 bg-primary/10 px-4 py-2 rounded-lg">
                        + Register New Branch
                    </button>
                </div>
                <% if (branches && branches.length > 0 && products && products.length > 0) { %>
                    <div class="overflow-x-auto border border-border rounded-lg bg-background">
                        <table class="w-full text-left text-sm whitespace-nowrap">
                            <thead class="bg-muted text-muted-fg uppercase tracking-wider text-xs border-b border-border">
                                <tr>
                                    <th class="p-4 font-bold sticky left-0 bg-muted border-r border-border z-10 w-56">Delivery Branch</th>
                                    <% products.forEach(product => { %>
                                        <% const finalPrice = Math.round(parseFloat(product.base_rate) * (1 + (parseFloat(product.gst_percentage) || 0) / 100)); %>
                                        <th class="p-4 font-bold min-w-[140px]">
                                            <div class="flex flex-col">
                                                <span class="text-foreground text-sm"><%= product.name %></span>
                                                <span class="text-[10px] lowercase opacity-80 font-normal">₹<%= finalPrice %> / <%= product.unit %></span>
                                            </div>
                                        </th>
                                    <% }) %>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-border">
                                <% branches.forEach(branch => { %>
                                    <tr class="hover:bg-muted/20 transition group">
                                        <td class="p-4 sticky left-0 bg-background group-hover:bg-muted/50 border-r border-border z-10">
                                            <div class="flex items-center justify-between">
                                                <span class="font-bold"><%= branch.branch_name %></span>
                                                <button type="button" onclick="deleteBranch('<%= branch.id || branch.branch_id %>', '<%= branch.branch_name %>')" title="Remove Branch" class="flex-shrink-0 ml-2 opacity-0 group-hover:opacity-100 text-muted-fg hover:text-red-500 hover:bg-red-50 transition p-1.5 rounded-md flex items-center justify-center">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <path d="M3 6h18"></path>
                                                        <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
                                                        <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
                                                    </svg>
                                                </button>
                                            </div>
                                        </td>
                                        <% products.forEach(product => { %>
                                            <td class="p-3">
                                                <div class="flex items-end gap-1">
                                                    <input type="number" name="orders[b_<%= branch.id || branch.branch_id %>][p_<%= product.id %>]" step="0.01" min="0" placeholder="-" class="w-full bg-input border border-border focus:border-primary rounded px-3 py-2 outline-none transition font-mono text-base">
                                                </div>
                                            </td>
                                        <% }) %>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-8 flex justify-end pt-6 border-t border-border">
                        <button type="submit" class="bg-primary hover:bg-primary/90 text-primary-fg px-8 py-3 rounded font-medium text-lg transition shadow-lg flex items-center gap-2">
                            🛒 Submit Bulk Order
                        </button>
                    </div>
                <% } else { %>
                    <div class="text-center py-12 border-2 border-dashed border-border rounded-lg bg-muted/10">
                        <p class="text-muted-fg font-medium">Please add at least one branch to view the order matrix.</p>
                    </div>
                <% } %>
            </form>
        </div>

        <div id="section-history" class="hidden">
            <div class="bg-card rounded-xl border border-border overflow-x-auto shadow-sm">
                <table class="w-full text-left text-sm min-w-[700px] md:min-w-0">
                    <thead class="bg-primary text-primary-fg">
                        <tr>
                            <th class="p-4 font-medium tracking-wider">Order ID</th>
                            <th class="p-4 font-medium tracking-wider">Branches</th>
                            <th class="p-4 font-medium tracking-wider">Date</th>
                            <th class="p-4 font-medium tracking-wider">Status</th>
                            <th class="p-4 font-medium tracking-wider text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border">
                        <% if (orders && orders.length > 0) { %>
                            <% orders.forEach(order => { %>
                                <tr class="hover:bg-muted/20 transition">
                                    <td class="p-4 font-mono font-bold">ORD-<%= String(order.id).padStart(4, '0') %></td>
                                    <td class="p-4"><%= order.branch_names %></td>
                                    <td class="p-4"><%= new Date(order.created_at).toLocaleDateString() %></td>
                                    <td class="p-4">
                                        <% if (order.status === 'Fulfilled') { %>
                                            <span class="px-3 py-1 bg-green-100 text-green-800 border border-green-200 rounded-full text-xs font-bold">✔ Fulfilled</span>
                                        <% } else { %>
                                            <span class="px-3 py-1 bg-yellow-100 text-yellow-800 border border-yellow-200 rounded-full text-xs font-bold"><%= order.status %></span>
                                        <% } %>
                                    </td>
                                    <td class="p-4 text-right flex justify-end gap-2">
                                        <button onclick="viewOrderDetails('<%= order.id %>')" class="text-primary hover:text-accent font-medium text-sm border border-primary/20 hover:border-accent bg-primary/5 px-3 py-1.5 rounded transition">👁️ View Items</button>
                                        <% if (order.status !== 'Fulfilled') { %>
                                            <button onclick="editOrder('<%= order.id %>')" class="text-white hover:bg-accent/90 font-medium text-sm bg-accent px-3 py-1.5 rounded transition shadow-sm">✏️ Edit</button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="5" class="p-8 text-center text-muted-fg">No orders found.</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="section-reports" class="hidden">
            <div class="bg-card rounded-xl border border-border p-6 md:p-8 shadow-sm max-w-2xl">
                <h3 class="text-xl font-serif-custom font-bold text-foreground mb-2">Generate Order Data</h3>
                <p class="text-sm text-muted-fg mb-8">Download your complete order history and itemized breakdowns for your internal accounting.</p>
                <form action="/dashboard/reports/generate" method="GET" target="_blank" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-bold text-muted-fg mb-2 uppercase tracking-wider">Start Date</label>
                            <input type="date" name="startDate" required class="w-full bg-input border border-border focus:border-primary rounded px-4 py-3 outline-none transition">
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-muted-fg mb-2 uppercase tracking-wider">End Date</label>
                            <input type="date" name="endDate" required class="w-full bg-input border border-border focus:border-primary rounded px-4 py-3 outline-none transition">
                        </div>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-bold text-muted-fg mb-2 uppercase tracking-wider">Filter by Branch (Optional)</label>
                            <select name="branchId" class="w-full bg-input border border-border focus:border-primary rounded px-4 py-3 outline-none transition appearance-none">
                                <option value="ALL">All Branches</option>
                                <% if (branches) { branches.forEach(branch => { %>
                                    <option value="<%= branch.id %>"><%= branch.branch_name %></option>
                                <% }) } %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-muted-fg mb-2 uppercase tracking-wider">Report Type</label>
                            <select name="reportType" required class="w-full bg-input border border-border focus:border-primary rounded px-4 py-3 outline-none transition appearance-none">
                                <option value="tofu">Tofu (Hard Paneer)</option>
                                <option value="dairy">Dairy Products</option>
                            </select>
                        </div>
                    </div>
                    <div class="pt-4">
                        <button type="submit" class="w-full bg-foreground hover:bg-black text-background font-medium py-3 rounded transition shadow flex justify-center items-center gap-2">⬇️ Download Report</button>
                    </div>
                </form>
            </div>
        </div>

    </main>

    <div id="branchModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-card rounded-xl max-w-md w-full shadow-2xl overflow-hidden border border-border">
            <div class="px-6 py-4 border-b border-border bg-muted/30 flex justify-between items-center">
                <h3 class="font-bold text-foreground font-serif-custom tracking-wide">Register New Branch</h3>
                <button type="button" onclick="document.getElementById('branchModal').classList.add('hidden')" class="text-muted-fg hover:text-foreground text-2xl leading-none">&times;</button>
            </div>
            <form action="/customer/add-branch" method="POST" class="p-6">
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs font-bold text-muted-fg mb-1 uppercase tracking-wider">Branch Name</label>
                        <input type="text" name="branch_name" required placeholder="e.g. Andheri West" class="w-full bg-input border border-border rounded px-3 py-2 outline-none focus:border-primary transition">
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-muted-fg mb-1 uppercase tracking-wider">Address</label>
                        <textarea name="address" rows="2" required class="w-full bg-input border border-border rounded px-3 py-2 outline-none focus:border-primary transition"></textarea>
                    </div>
                </div>
                <div class="mt-8 flex gap-3">
                    <button type="button" onclick="document.getElementById('branchModal').classList.add('hidden')" class="flex-1 px-4 py-2.5 border border-border text-foreground font-medium rounded hover:bg-muted transition">Cancel</button>
                    <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-primary-fg font-medium rounded hover:bg-primary/90 transition shadow">Save Branch</button>
                </div>
            </form>
        </div>
    </div>

    <div id="invoiceModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-card rounded-xl max-w-3xl w-full shadow-2xl overflow-hidden border border-border flex flex-col max-h-[90vh]">
            <div class="px-6 py-4 border-b border-border bg-muted/30 flex justify-between items-center">
                <div>
                    <h3 class="font-bold text-foreground font-serif-custom tracking-wide text-lg">Master Purchase Order</h3>
                    <p id="modal-order-id" class="text-sm font-mono text-muted-fg mt-1"></p>
                </div>
                <button type="button" onclick="document.getElementById('invoiceModal').classList.add('hidden')" class="text-muted-fg hover:text-foreground text-3xl leading-none">&times;</button>
            </div>
            <div class="p-4 sm:p-6 overflow-y-auto">
                <div class="flex flex-col sm:flex-row justify-between gap-4 mb-6 bg-background border border-border p-4 rounded-lg">
                    <div>
                        <p class="text-xs text-muted-fg uppercase tracking-widest font-bold mb-1">Entity</p>
                        <p id="modal-branch-name" class="font-bold text-foreground"></p>
                        <p id="modal-branch-address" class="text-sm text-muted-fg mt-1"></p>
                    </div>
                    <div class="text-left sm:text-right">
                        <p class="text-xs text-muted-fg uppercase tracking-widest font-bold mb-1">Status</p>
                        <div id="modal-status"></div>
                    </div>
                </div>
                <div class="overflow-x-auto border border-border rounded-lg">
                    <table class="w-full text-left text-sm min-w-[550px]">
                    <thead class="bg-muted text-muted-fg">
                        <tr>
                            <th class="p-3 font-medium">Branch</th>
                            <th class="p-3 font-medium">Product</th>
                            <th class="p-3 font-medium text-center" id="modal-qty-header">Qty</th>
                            <th class="p-3 font-medium text-right">Base Rate</th>
                            <th class="p-3 font-medium text-right">Total (Incl. GST)</th>
                        </tr>
                    </thead>
                    <tbody id="modal-items-tbody" class="divide-y divide-border"></tbody>
                </table>
                <div class="mt-4 text-right pr-3">
                    <p class="text-muted-fg text-sm">Estimated Total Amount:</p>
                    <p id="modal-grand-total" class="text-2xl font-bold font-mono text-primary"></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Order Modal -->
    <div id="editOrderModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-card rounded-xl max-w-4xl w-full shadow-2xl overflow-hidden border border-border flex flex-col max-h-[90vh]">
            <div class="px-6 py-4 border-b border-border bg-muted/30 flex justify-between items-center">
                <div>
                    <h3 class="font-bold text-foreground font-serif-custom tracking-wide text-lg">Edit Master Purchase Order</h3>
                    <p id="edit-modal-order-id" class="text-sm font-mono text-muted-fg mt-1"></p>
                </div>
                <button type="button" onclick="document.getElementById('editOrderModal').classList.add('hidden')" class="text-muted-fg hover:text-foreground text-3xl leading-none">&times;</button>
            </div>
            <form id="form-edit-order" action="" method="POST" class="flex-1 flex flex-col overflow-hidden">
                <div class="p-4 sm:p-6 overflow-y-auto flex-1">
                    <div class="overflow-x-auto border border-border rounded-lg bg-background">
                        <table class="w-full text-left text-sm whitespace-nowrap">
                            <thead class="bg-muted text-muted-fg uppercase tracking-wider text-xs border-b border-border">
                                <tr>
                                    <th class="p-4 font-bold sticky left-0 bg-muted border-r border-border z-10 w-56">Delivery Branch</th>
                                    <% products.forEach(product => { %>
                                        <th class="p-4 font-bold min-w-[140px]"><%= product.name %> (<%= product.unit %>)</th>
                                    <% }) %>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-border">
                                <% branches.forEach(branch => { %>
                                    <tr class="hover:bg-muted/20 transition group">
                                        <td class="p-4 sticky left-0 bg-background group-hover:bg-muted/50 border-r border-border z-10">
                                            <span class="font-bold"><%= branch.branch_name %></span>
                                        </td>
                                        <% products.forEach(product => { %>
                                            <td class="p-3">
                                                <input type="number" 
                                                       name="orders[b_<%= branch.id || branch.branch_id %>][p_<%= product.id %>]" 
                                                       id="edit_input_b_<%= branch.id || branch.branch_id %>_p_<%= product.id %>"
                                                       step="0.01" 
                                                       min="0" 
                                                       placeholder="-" 
                                                       class="w-full bg-input border border-border focus:border-primary rounded px-3 py-2 outline-none transition font-mono text-base">
                                            </td>
                                        <% }) %>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="px-6 py-4 border-t border-border bg-muted/30 flex justify-end gap-3">
                    <button type="button" onclick="document.getElementById('editOrderModal').classList.add('hidden')" class="px-4 py-2 border border-border text-foreground font-medium rounded hover:bg-muted transition">Cancel</button>
                    <button type="submit" class="px-6 py-2 bg-primary text-primary-fg font-medium rounded hover:bg-primary/90 transition shadow">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function switchTab(tabId) {
            document.getElementById('section-order').classList.add('hidden');
            document.getElementById('section-history').classList.add('hidden');
            document.getElementById('section-reports').classList.add('hidden');
            ['order', 'history', 'reports'].forEach(id => {
                const btn = document.getElementById('tab-btn-' + id);
                btn.classList.remove('border-primary', 'text-primary', 'font-bold');
                btn.classList.add('border-transparent', 'text-muted-fg');
            });
            document.getElementById('section-' + tabId).classList.remove('hidden');
            const activeBtn = document.getElementById('tab-btn-' + tabId);
            activeBtn.classList.remove('border-transparent', 'text-muted-fg');
            activeBtn.classList.add('border-primary', 'text-primary', 'font-bold');
        }

        async function viewOrderDetails(orderId) {
            try {
                const response = await fetch(`/customer/order/${orderId}`);
                if (!response.ok) throw new Error("Failed to fetch order details");
                
                const data = await response.json();
                const order = data.order;
                const items = data.items;

                document.getElementById('modal-order-id').innerText = `ORD-${String(order.id).padStart(4, '0')} • ${new Date(order.created_at).toLocaleDateString()}`;
                document.getElementById('modal-branch-name').innerText = "Master Corporate Order";
                document.getElementById('modal-branch-address').innerText = "Multiple Delivery Locations";
                
                const isOrderFulfilled = order.status === 'Fulfilled';
                document.getElementById('modal-status').innerHTML = isOrderFulfilled 
                    ? `<span class="px-3 py-1 bg-green-100 text-green-800 border border-green-200 rounded-full text-xs font-bold">✔ Fulfilled</span>`
                    : `<span class="px-3 py-1 bg-yellow-100 text-yellow-800 border border-yellow-200 rounded-full text-xs font-bold">${order.status}</span>`;

                document.getElementById('modal-qty-header').innerText = isOrderFulfilled ? "Delivered Qty" : "Requested Qty";

                const tbody = document.getElementById('modal-items-tbody');
                tbody.innerHTML = ''; 
                let grandTotal = 0;

                items.forEach(item => {
                    const basePrice = parseFloat(item.rate_at_order);
                    const gstPercent = parseFloat(item.gst_at_order) || 0;
                    const priceWithGst = basePrice * (1 + (gstPercent / 100));
                    
                    const hasDeliveredQty = item.delivered_quantity !== null && item.delivered_quantity !== undefined;
                    
                    const activeQty = (isOrderFulfilled && hasDeliveredQty) ? parseFloat(item.delivered_quantity) : parseFloat(item.ordered_quantity);
                    
                    const rowTotal = priceWithGst * activeQty;
                    grandTotal += rowTotal;

                    const qtyDisplay = isOrderFulfilled 
                        ? `<span class="text-green-600 font-bold">${activeQty}</span>`
                        : `${activeQty}`;

                    const tr = document.createElement('tr');
                    tr.className = "hover:bg-muted/10 transition border-b border-border/50";
                    tr.innerHTML = `
                        <td class="p-3 font-bold text-xs text-primary uppercase tracking-wider">${item.branch_name}</td>
                        <td class="p-3 font-medium">${item.product_name} <span class="text-xs text-muted-fg ml-1">(${item.unit})</span></td>
                        <td class="p-3 text-center font-mono">${qtyDisplay}</td>
                        <td class="p-3 text-right text-muted-fg font-mono">₹${basePrice.toFixed(2)}</td>
                        <td class="p-3 text-right font-bold font-mono text-foreground">₹${rowTotal.toFixed(2)}</td>
                    `;
                    tbody.appendChild(tr);
                });

                document.getElementById('modal-grand-total').previousElementSibling.innerText = isOrderFulfilled ? "Final Invoice Total:" : "Estimated Total Amount:";
                document.getElementById('modal-grand-total').innerText = `₹${Math.round(grandTotal).toLocaleString()}`;
                document.getElementById('invoiceModal').classList.remove('hidden');
            } catch (error) {
                console.error("Error:", error);
                alert("Could not load order details.");
            }
        }

        async function editOrder(orderId) {
            try {
                const response = await fetch(`/customer/order/${orderId}`);
                if (!response.ok) throw new Error("Failed to fetch order details");
                
                const data = await response.json();
                const order = data.order;
                const items = data.items;

                if (order.status === 'Fulfilled') {
                    alert("This order is already fulfilled and cannot be edited.");
                    return;
                }

                document.getElementById('form-edit-order').action = `/customer/edit-order/${orderId}`;
                document.getElementById('edit-modal-order-id').innerText = `ORD-${String(order.id).padStart(4, '0')} • Edit requested quantities`;

                // Clear all input fields first
                const inputs = document.querySelectorAll('#form-edit-order input[type="number"]');
                inputs.forEach(input => input.value = '');

                // Populate inputs with ordered quantities
                items.forEach(item => {
                    const inputId = `edit_input_b_${item.branch_id}_p_${item.product_id}`;
                    const input = document.getElementById(inputId);
                    if (input) {
                        input.value = parseFloat(item.ordered_quantity) || '';
                    }
                });

                document.getElementById('editOrderModal').classList.remove('hidden');
            } catch (error) {
                console.error("Error loading order for edit:", error);
                alert("Could not load order for editing.");
            }
        }

        // NEW: Handles the invisible branch deletion cleanly
        async function deleteBranch(branchId, branchName) {
            if (confirm(`Are you sure you want to remove ${branchName}?`)) {
                try {
                    const response = await fetch(`/customer/delete-branch/${branchId}`, {
                        method: 'POST'
                    });
                    
                    if (response.ok) {
                        window.location.reload(); 
                    } else {
                        const errorMessage = await response.text();
                        alert(errorMessage || "Could not delete branch.");
                    }
                } catch (error) {
                    console.error("Error:", error);
                    alert("A network error occurred.");
                }
            }
        }
    </script>
</body>
</html>
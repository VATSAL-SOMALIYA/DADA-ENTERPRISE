<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DADA Enterprise | Login</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="min-h-screen flex text-foreground">

    <div class="hidden lg:flex w-[45%] bg-primary text-primary-fg p-12 flex-col relative overflow-hidden">
        <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-white opacity-5 rounded-full blur-2xl"></div>
        <div class="absolute top-20 -left-20 w-72 h-72 bg-black opacity-10 rounded-full blur-xl"></div>

        <div class="relative z-10">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-accent text-primary flex items-center justify-center font-bold text-xl rounded">D</div>
                <div>
                    <h2 class="text-xl font-serif-custom tracking-wider font-semibold">DADA ENTERPRISE</h2>
                    <p class="text-sm opacity-60 font-mono tracking-widest uppercase mt-1">Order Management System</p>
                </div>
            </div>
        </div>

        <div class="relative z-10 max-w-md flex-1 flex flex-col justify-center">
            <h1 class="text-5xl lg:text-6xl font-serif-custom leading-tight">
                Fresh Dairy.<br>
                <span class="text-accent">Smart Orders.</span>
            </h1>
            <p class="mt-6 text-lg opacity-80 leading-relaxed">
                Manage Tofu, Curd, Milk & Buttermilk orders seamlessly — from dispatch to delivery, all in one place.
            </p>

            <div class="flex flex-wrap gap-3 mt-8">
                <span class="px-4 py-2 rounded-full border border-white/20 bg-white/5 backdrop-blur-sm text-sm flex items-center gap-2">🥛 Milk</span>
                <span class="px-4 py-2 rounded-full border border-white/20 bg-white/5 backdrop-blur-sm text-sm flex items-center gap-2">🥣 Curd</span>
                <span class="px-4 py-2 rounded-full border border-white/20 bg-white/5 backdrop-blur-sm text-sm flex items-center gap-2">🧈 Tofu</span>
                <span class="px-4 py-2 rounded-full border border-white/20 bg-white/5 backdrop-blur-sm text-sm flex items-center gap-2">🥤 Buttermilk</span>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-[55%] bg-background flex flex-col justify-center items-center p-8 relative">
        <div class="w-full max-w-md">
            
            <!-- Mobile Brand Header (Visible only on mobile/tablet) -->
            <div class="lg:hidden flex flex-col items-center mb-10 text-center">
                <div class="flex items-center gap-3 justify-center mb-3">
                    <div class="w-9 h-9 bg-accent text-primary flex items-center justify-center font-bold text-lg rounded shadow">D</div>
                    <h2 class="text-lg font-serif-custom tracking-wider font-semibold text-primary">DADA ENTERPRISE</h2>
                </div>
                <p class="text-xs opacity-60 font-mono tracking-widest uppercase mb-4 text-muted-fg">Order Management System</p>
                <div class="flex gap-2 justify-center flex-wrap">
                    <span class="px-3 py-1.5 rounded-full border border-primary/10 bg-primary/5 text-xs flex items-center gap-1.5 text-primary">🥛 Milk</span>
                    <span class="px-3 py-1.5 rounded-full border border-primary/10 bg-primary/5 text-xs flex items-center gap-1.5 text-primary">🥣 Curd</span>
                    <span class="px-3 py-1.5 rounded-full border border-primary/10 bg-primary/5 text-xs flex items-center gap-1.5 text-primary">🧈 Tofu</span>
                    <span class="px-3 py-1.5 rounded-full border border-primary/10 bg-primary/5 text-xs flex items-center gap-1.5 text-primary">🥤 Buttermilk</span>
                </div>
            </div>
            
            <div class="bg-muted p-1 rounded-lg flex mb-12">
                <button id="tab-signin" onclick="switchTab('signin')" class="w-1/2 bg-primary text-primary-fg py-2.5 rounded shadow-sm text-sm font-medium transition">Sign In</button>
                <button id="tab-register" onclick="switchTab('register')" class="w-1/2 text-muted-fg py-2.5 rounded text-sm font-medium hover:text-foreground transition">Create Account</button>
            </div>

            <% if (error) { %>
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
                    <span class="block sm:inline"><%= error %></span>
                </div>
            <% } %>

            <!-- Sign In Form -->
            <form id="form-signin" action="/login" method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium mb-2">Email Address</label>
                    <input type="email" name="email" required placeholder="orders@dadaenterprise.com" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                </div>
                <div>
                    <div class="flex justify-between items-center mb-2">
                        <label class="block text-sm font-medium">Password</label>
                        <a href="javascript:void(0)" onclick="toggleModal(true)" class="text-xs text-accent hover:underline">Forgot password?</a>
                    </div>
                    <div class="relative">
                        <input type="password" id="password" name="password" required placeholder="Enter your password" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition pr-10">
                        <button type="button" id="hover-eye" class="absolute inset-y-0 right-0 pr-3 flex items-center text-muted-fg hover:text-foreground cursor-pointer">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        </button>
                    </div>
                </div>
                <!-- Tip removed -->
                <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-primary-fg font-medium py-3 rounded transition flex justify-center items-center gap-2 shadow-lg">
                    Sign In to Dashboard <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
                </button>
            </form>

            <!-- Register Form (Hidden) -->
            <form id="form-register" action="/register" method="POST" class="space-y-6 hidden">
                <div>
                    <label class="block text-sm font-medium mb-2">Register As</label>
                    <select id="register-role" name="role" onchange="toggleCompanyField()" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                        <option value="customer">Customer (Store Manager)</option>
                        <option value="admin">Administrator</option>
                    </select>
                </div>
                <div id="company-field">
                    <label class="block text-sm font-medium mb-2">Company Name</label>
                    <input type="text" id="company_name" name="company_name" required placeholder="Enter Company Name" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Email Address</label>
                    <input type="email" name="email" required placeholder="email@dadaenterprise.com" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Password</label>
                    <input type="password" name="password" required placeholder="Create a password" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                </div>
                <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-primary-fg font-medium py-3 rounded transition shadow-lg">Register Account</button>
            </form>
            
            <div class="mt-16 text-center text-xs text-muted-fg">© 2026 DADA Enterprise · All rights reserved</div>
        </div>
    </div>

    <script>
        function switchTab(type) {
            const isReg = (type === 'register');
            document.getElementById('form-signin').classList.toggle('hidden', isReg);
            document.getElementById('form-register').classList.toggle('hidden', !isReg);
            const btnS = document.getElementById('tab-signin');
            const btnR = document.getElementById('tab-register');
            btnS.className = isReg ? "w-1/2 text-muted-fg py-2.5 rounded text-sm font-medium transition" : "w-1/2 bg-primary text-primary-fg py-2.5 rounded shadow-sm text-sm font-medium transition";
            btnR.className = isReg ? "w-1/2 bg-primary text-primary-fg py-2.5 rounded shadow-sm text-sm font-medium transition" : "w-1/2 text-muted-fg py-2.5 rounded text-sm font-medium transition";
        }

        function toggleCompanyField() {
            const role = document.getElementById('register-role').value;
            const companyField = document.getElementById('company-field');
            const companyInput = document.getElementById('company_name');
            if (role === 'admin') {
                companyField.classList.add('hidden');
                companyInput.removeAttribute('required');
            } else {
                companyField.classList.remove('hidden');
                companyInput.setAttribute('required', 'required');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            <% if (typeof activeTab !== 'undefined' && activeTab === 'register') { %>
                switchTab('register');
            <% } %>
            const passwordInput = document.getElementById('password');
            const hoverEye = document.getElementById('hover-eye');
            if (passwordInput && hoverEye) {
                hoverEye.addEventListener('click', () => {
                    const isPassword = (passwordInput.type === 'password');
                    passwordInput.type = isPassword ? 'text' : 'password';
                    
                    if (isPassword) {
                        // Eye Slash Icon (Password Visible)
                        hoverEye.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>`;
                    } else {
                        // Eye Open Icon (Password Hidden)
                        hoverEye.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`;
                    }
                });
            }
        });
        function toggleModal(show) {
    const modal = document.getElementById('forgotModal');
    modal.classList.toggle('hidden', !show);
}
    </script>
    <div id="forgotModal" class="fixed inset-0 z-[100] hidden flex items-center justify-center p-4 bg-black/60 backdrop-blur-md transition-all duration-300">
        <div class="bg-card w-full max-w-md rounded-2xl shadow-[0_25px_60px_-15px_rgba(30,58,40,0.3)] border border-[#c8a96e]/20 overflow-hidden transform scale-100 transition-all duration-300">
            <div class="px-6 py-5 border-b border-border bg-gradient-to-r from-[#1e3a28]/5 via-[#1e3a28]/2 to-transparent flex justify-between items-center">
                <h3 class="text-lg font-bold text-foreground font-serif-custom tracking-wide">Reset Password</h3>
                <button type="button" onclick="toggleModal(false)" class="w-8 h-8 rounded-full flex items-center justify-center bg-muted/60 hover:bg-muted text-muted-fg hover:text-foreground transition-all duration-200 text-xl leading-none">&times;</button>
            </div>
            <form action="/forgot-password" method="POST" class="p-6 sm:p-8 space-y-5">
                <p class="text-sm text-[#6b6355] leading-relaxed font-medium">Enter your registered email address below. We will generate a password reset link and send it to you.</p>
                <div>
                    <label class="block text-xs font-bold text-muted-fg mb-1.5 uppercase tracking-wider">Email Address</label>
                    <input type="email" name="email" required placeholder="e.g. orders@dadaenterprise.com" 
                           class="w-full bg-[#fcfaf7] border border-border/80 focus:border-[#c8a96e] focus:ring-1 focus:ring-[#c8a96e] rounded-xl px-4 py-3 outline-none transition text-sm text-foreground placeholder:text-muted-fg/60">
                </div>
                <div class="pt-2 flex gap-3">
                    <button type="button" onclick="toggleModal(false)" class="flex-1 px-4 py-3 border border-border text-foreground font-semibold rounded-xl hover:bg-muted/40 transition-all duration-200">Cancel</button>
                    <button type="submit" class="flex-1 px-4 py-3 bg-primary text-primary-fg font-semibold rounded-xl hover:bg-primary/95 transition-all duration-200 shadow-md hover:shadow-lg">Send Link</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
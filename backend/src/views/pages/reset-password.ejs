<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DADA Enterprise | Reset Password</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="min-h-screen flex text-foreground">

    <!-- LEFT PANEL: Same as Login -->
    <div class="hidden lg:flex w-[45%] bg-primary text-primary-fg p-12 flex-col relative overflow-hidden">
        <div class="absolute -bottom-32 -right-32 w-96 h-96 bg-white opacity-5 rounded-full blur-2xl"></div>
        <div class="absolute top-20 -left-20 w-72 h-72 bg-black opacity-10 rounded-full blur-xl"></div>
        <div class="relative z-10">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 bg-accent text-primary flex items-center justify-center font-bold text-xl rounded">D</div>
                <div>
                    <h2 class="text-xl font-serif-custom tracking-wider font-semibold">DADA ENTERPRISE</h2>
                    <p class="text-sm opacity-60 font-mono tracking-widest uppercase mt-1">Order Management System</p>
                </div>
            </div>
        </div>
        <div class="relative z-10 max-w-md flex-1 flex flex-col justify-center">
            <h1 class="text-5xl lg:text-6xl font-serif-custom leading-tight">Fresh Dairy.<br><span class="text-accent">Smart Orders.</span></h1>
            <p class="mt-6 text-lg opacity-80 leading-relaxed">Manage Tofu, Curd, Milk & Buttermilk orders seamlessly — from dispatch to delivery, all in one place.</p>
        </div>
    </div>

    <!-- RIGHT PANEL: Reset Password Form -->
    <div class="w-full lg:w-[55%] bg-background flex flex-col justify-center items-center p-8 relative">
        <div class="w-full max-w-md">
            <h2 class="text-2xl font-bold mb-8">Set New Password</h2>
            
            <form action="/reset-password/<%= token %>" method="POST" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium mb-2">New Password</label>
                    <input type="password" name="password" required placeholder="Enter new password" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Confirm Password</label>
                    <input type="password" name="confirm_password" required placeholder="Re-enter your password" class="w-full bg-input border border-transparent focus:border-accent focus:ring-1 focus:ring-accent rounded px-4 py-3 outline-none transition">
                </div>
                <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-primary-fg font-medium py-3 rounded transition shadow-lg">
                    Update Password
                </button>
            </form>
            
            <div class="mt-16 text-center text-xs text-muted-fg">© 2026 DADA Enterprise · All rights reserved</div>
        </div>
    </div>
</body>
</html>